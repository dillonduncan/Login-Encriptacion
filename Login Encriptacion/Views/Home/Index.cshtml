@model Usuario
@{
    ViewData["Title"] = "Ingreso";
}

<div class="row justify-content-center">
    <div class="col-md-4 card shadow p-4 mt-5">
        <h3 class="text-center">Iniciar Sesion</h3>
        <hr />

        @if(ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }
        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label class="form-label">Usuario</label>
                <input name="user" class="form-control" placeholder="admin" required/>
            </div>
            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input name="password" type="password" class="form-control" placeholder="1234" required/>
            </div>
            <button type="submit" class="btn btn-primary w-100">Entrar</button>
        </form>
    </div>
</div>
