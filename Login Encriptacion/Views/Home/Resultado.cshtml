@model Login_Encriptacion.Models.ViewModels.ViewModelResult
@{
    ViewData["Tittle"] = "Resultado del Cifrado";
}

<div class="container mt-4">
    <h2>Analisis de Seguridad</h2>
    <hr />

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card border-primary">
                <div class="card-header bg-primary text-white">Encriptacion Simetrica (AES)</div>
                <div class="card-body">
                    <h6>Texto Cifrado:</h6>
                    <p class="text-break bg-light p-2"> <code>@Model.SimetricoCifrado</code> </p>

                    <h6 class="mt-3">Texto Descifrado:</h6>
                    <p class="text-success fw-bold">
                        @inject Login_Encriptacion.Services.CryptoService Crypto
                        @Crypto.DesencriptarSimetrico(Model.SimetricoCifrado)
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card border-warning">
                <div class="card-header bg-warning text-dark">Encriptacion Asimetrica (RSA)</div>
                <div class="card-body">
                    <h6>Texto Cifrado (Llave publica):</h6>
                    <p class="text-break bg-light p-2"> <code>@Model.AsimetricoCifrado</code> </p>

                    <h6>Texto Descifrado (Llave privada):</h6>
                    <p class="text-success fw-bold">
                        @Crypto.DesencriptarAsimetrico(Model.AsimetricoCifrado)
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="alert alert-info">
        <strong>Dato Original:</strong> @Model.Original
    </div>

    <a asp-action="Formulario" class="btn btn-outline-secondary">Volver</a>
</div>